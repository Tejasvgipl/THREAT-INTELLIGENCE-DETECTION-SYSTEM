# CyberSentinel Environment Variables
# Copy this to .env and fill in real values

# Optional: AbuseIPDB API key for live threat intel
# Get free key at https://www.abuseipdb.com/register
ABUSEIPDB_KEY=your_key_here

# Redis password (leave blank for local dev)
REDIS_PASSWORD=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
